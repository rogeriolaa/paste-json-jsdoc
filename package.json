{
  "name": "paste-json-jsdoc",
  "displayName": "paste-json-jsdoc",
  "publisher": "n0n3br",
  "description": "Paste raw JSON and instantly turn it into clean JSDoc @typedef definitions inside VS Code. This extension helps JavaScript developers generate reusable type annotations from API responses, config objects, or sample payloads without writing JSDoc by hand.",
  "version": "0.0.1",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.116.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rogeriolaa/paste-json-jsdoc"
  },
  "categories": [
    "Other"
  ],
  "keybindings": [
    {
      "command": "pasteJsonAsJsdoc.generate",
      "key": "ctrl+alt+j",
      "mac": "cmd+alt+j",
      "when": "editorTextFocus"
    }
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pasteJsonAsJsdoc.generate",
        "title": "Paste JSON as JSDoc Typedef"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
